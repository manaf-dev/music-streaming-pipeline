# Copy this file to terraform.tfvars and fill in the values for your repo.
# terraform.tfvars is gitignored so your real values stay local.

github_org  = "YOUR-GITHUB-ORG-OR-USERNAME"
github_repo = "music-streaming-pipeline"

# Region only matters for the provider session; IAM resources are global.
region = "eu-central-1"

# Set to false if a GitHub OIDC provider already exists in your AWS account
# (re-creating fails with EntityAlreadyExists). Run `aws iam list-open-id-connect-providers`
# to check.
create_oidc_provider = true
